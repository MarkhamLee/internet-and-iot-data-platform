{
  "name": "github_actions_tracking",
  "version": "1.0.0",
  "description": "Node.js ETL pipeline for GitHub tracking",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "audit": "npm audit --audit-level=high",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "engines": {
    "node": ">=18.18.0 <23"
  },
  "overrides": {
    "minimatch@^3": "3.1.4",
    "minimatch@^9": "9.0.8"
  },
  "keywords": [],
  "author": "Markham Lee",
  "license": "MIT",
  "dependencies": {
    "@influxdata/influxdb-client": "1.33.2",
    "ajv": "8.18.0",
    "axios": "^1.15.2",
    "esbuild": "0.27.2",
    "flatted": "3.4.2",
    "follow-redirects": "^1.16.0",
    "handlebars": "4.7.9",
    "octokit": "^3.1.2",
    "picomatch": "2.3.2",
    "tsx": "^4.7.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^18.19.21",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.3"
  }
}